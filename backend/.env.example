# ─── App ───────────────────────────────────────────────────────────────
APP_NAME=PredictGoal
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── Injective Testnet ──────────────────────────────────────────────────
INJECTIVE_NETWORK=testnet
INJECTIVE_RPC_URL=https://testnet.sentry.tm.injective.network:443
INJECTIVE_CHAIN_ID=injective-888
INJECTIVE_GRPC_URL=testnet.grpc.injective.network:443
INJECTIVE_MNEMONIC=

# ─── CCTP Testnet (stubbed — values unused until real integration) ──────
CCTP_API_KEY=
CCTP_SOURCE_DOMAIN=0
CCTP_TOKEN_MESSENGER_ADDRESS=

# ─── x402 pay-per-use ───────────────────────────────────────────────────
# Recipient address for x402 payments (Injective/EVM testnet address).
# Leave blank to run in dev-mode passthrough (payments not enforced).
X402_PAYMENT_RECIPIENT=
X402_PROTOCOL_FEE_BPS=50

# ─── Admin ──────────────────────────────────────────────────────────────
# Required for market settlement. Set a strong value in production.
ADMIN_SETTLE_KEY=

# ─── World Cup Data (football-data.org) ─────────────────────────────────
# Get a free key at https://www.football-data.org/
# Leave blank to use 4 built-in demo placeholder matches.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC

# ─── CORS (comma-separated, no spaces) ──────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","https://your-vercel-app.vercel.app"]

# ─── Health check ───────────────────────────────────────────────────────
# Set to false to disable the /health endpoint (GET + HEAD).
HEALTH_CHECK_ENABLED=true

# ─── Redis (optional — not used by MVP) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
