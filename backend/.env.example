# App
APP_NAME=PredictGoal
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Injective Testnet
INJECTIVE_NETWORK=testnet
INJECTIVE_RPC_URL=https://testnet.sentry.tm.injective.network:443
INJECTIVE_CHAIN_ID=injective-888
INJECTIVE_GRPC_URL=testnet.grpc.injective.network:443
INJECTIVE_MNEMONIC=

# CCTP Testnet
CCTP_API_KEY=
CCTP_SOURCE_DOMAIN=0
CCTP_TOKEN_MESSENGER_ADDRESS=

# x402
X402_PAYMENT_RECIPIENT=
X402_PROTOCOL_FEE_BPS=50

# World Cup Data — get a free key at https://www.football-data.org/
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC

# CORS — comma-separated origins (add frontend URL in prod)
CORS_ORIGINS=["http://localhost:5173"]

# Auth
JWT_SECRET_KEY=
ADMIN_WALLET_ADDRESS=

# Database (optional — in-memory used by default for MVP)
DATABASE_URL=sqlite:///predictgoal.db

# Redis (optional — not needed for MVP)
REDIS_URL=redis://localhost:6379/0
